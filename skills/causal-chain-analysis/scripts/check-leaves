#!/usr/bin/env python3
"""Find leaf nodes in causal chain analysis files.

A leaf node is a node whose next non-empty line is not at a deeper indent,
i.e. it has no children. Such nodes are leaves of their folded subtree.

Filtering via CLI (mutually exclusive):
  (default)        show all leaf nodes (terminal or not)
  --terminal       show only leaf nodes marked as terminal / already analyzed
  --non-terminal   show only leaf nodes without such markers

Terminal markers recognized: ：末端 / ：上方已分析 / ：下方已分析 / ：单独深入分析

Only lines starting with '- ' or '* ' (after stripping tabs) are considered
nodes.

Usage: check-leaves <file> [--terminal | --non-terminal]
Exit codes: 0 = no leaves matched, 1 = leaves matched, 2 = usage error
"""

import argparse
import sys


def compute_depth(line):
    """Count leading tab characters."""
    return len(line) - len(line.lstrip('\t'))


def is_node(line):
    """Check if line is a causal chain node (starts with - or * after tabs)."""
    stripped = line.lstrip('\t')
    return stripped.startswith('- ') or stripped.startswith('* ')


def is_terminal(line):
    """Check if line is marked as terminal or already analyzed."""
    return any(m in line for m in ('：末端', '：上方已分析', '：下方已分析', '：单独深入分析'))


def main():
    parser = argparse.ArgumentParser(
        description='Find leaf nodes in causal chain analysis files.')
    parser.add_argument('file', help='causal chain analysis markdown file')
    group = parser.add_mutually_exclusive_group()
    group.add_argument('--terminal', action='store_true',
                       help='only show leaf nodes marked terminal/analyzed')
    group.add_argument('--non-terminal', action='store_true',
                       help='only show leaf nodes without terminal markers')
    args = parser.parse_args()

    try:
        with open(args.file, 'r', encoding='utf-8') as f:
            lines = f.read().splitlines()
    except Exception as e:
        parser.error(f"Error: {e}")

    leaves = []
    for i, line in enumerate(lines):
        if not is_node(line):
            continue

        depth = compute_depth(line)

        # Find next non-empty line
        next_depth = None
        for j in range(i + 1, len(lines)):
            if lines[j].strip() != '':
                next_depth = compute_depth(lines[j])
                break

        # Leaf = no child: next line is not deeper than current.
        if next_depth is None or next_depth <= depth:
            terminal = is_terminal(line)
            if args.terminal and not terminal:
                continue
            if args.non_terminal and terminal:
                continue
            content = line.lstrip('\t')
            if len(content) > 70:
                content = content[:70] + '...'
            leaves.append((i + 1, content))

    if leaves:
        for lineno, content in leaves:
            print(f"行 {lineno}：{content}")
        sys.exit(1)
    else:
        if args.terminal:
            print("无末端叶子节点")
        elif args.non_terminal:
            print("无未展开叶子节点")
        else:
            print("无叶子节点")
        sys.exit(0)


if __name__ == '__main__':
    main()
